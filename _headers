# ─── Cloudflare Pages : politique de cache ───────────────
# sw.js → JAMAIS en cache (sinon les users restent bloqués sur l'ancien SW)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# index.html → revalidé à chaque visite (pour récup le nouveau bundle.js)
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
/
  Cache-Control: no-cache, no-store, must-revalidate

# bundle.js → cache 5 min seulement (le SW gère le reste)
/bundle.js
  Cache-Control: public, max-age=300, must-revalidate

# Assets statiques (icônes SVG, css) → cache 1h, le SW prendra la suite
/icons/*
  Cache-Control: public, max-age=3600
/src/styles/*
  Cache-Control: public, max-age=3600
